[importlinter]
root_package = src

[importlinter:section_pages_not_cross_importing]
name = Section pages do not import each other
type = independence
modules =
    src.section_pages

[importlinter:section_pages_dependency_direction]
name = Section pages depend only on shared helper layers
type = layers
layers =
    src.section_pages
    src.page_context : src.wave_context : src.eda
    src.charts : src.sroi_charts : src.filters : src.data_loader : src.navigation : src.wave_schema
    src.config
